FROM python:3.11-slim

WORKDIR /app

COPY requirements.txt .

RUN pip install -r requirements.txt

COPY . .

RUN chmod +x run_server.sh

ARG DB_HOST
ARG DB_NAME
ARG DB_USER
ARG DB_PASSWORD
ARG DB_PORT
ARG SECRET_KEY
ARG STRIPE_SECRET_KEY
ARG EMAIL_SERVER_NAME
ARG EMAIL_SERVER_PORT
ARG ADMIN_EMAIL
ARG ADMIN_EMAIL_PASSWORD
ARG FRONTEND_URL

ENV DB_HOST=$DB_HOST
ENV DB_NAME=$DB_NAME
ENV DB_USER=$DB_USER
ENV DB_PASSWORD=$DB_PASSWORD
ENV DB_PORT=$DB_PORT
ENV SECRET_KEY=$SECRET_KEY
ENV STRIPE_SECRET_KEY=$STRIPE_SECRET_KEY
ENV FRONTEND_URL=$FRONTEND_URL
ENV EMAIL_SERVER_NAME=$EMAIL_SERVER_NAME
ENV EMAIL_SERVER_PORT=$EMAIL_SERVER_PORT
ENV ADMIN_EMAIL=$ADMIN_EMAIL
ENV ADMIN_EMAIL_PASSWORD=$ADMIN_EMAIL_PASSWORD

EXPOSE 8008

CMD [ "sh", "run_server.sh" ] 
